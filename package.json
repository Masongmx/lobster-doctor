{
  "name": "lobster-doctor",
  "version": "v4.2.0",
  "description": "🦞 龙虾医生 — OpenClaw workspace 健康管家。装得下，用得久，清得掉。",
  "main": "scripts/lobster_doctor.py",
  "author": "Masongmx",
  "license": "MIT",
  "keywords": [
    "health",
    "cleanup",
    "optimization",
    "skill-management",
    "token-saving",
    "memory-archive",
    "system-health",
    "workspace-structure",
    "tui",
    "textual"
  ],
  "engines": {
    "openclaw": ">=0.3.0"
  },
  "scripts": {
    "health": "python3 scripts/lobster_doctor.py health",
    "slim": "python3 scripts/lobster_doctor.py slim",
    "cleanup": "python3 scripts/lobster_doctor.py cleanup",
    "session": "python3 scripts/lobster_doctor.py session",
    "archive": "python3 scripts/lobster_doctor.py archive",
    "system-health": "python3 scripts/lobster_doctor.py system-health",
    "system-cleanup": "python3 scripts/lobster_doctor.py system-cleanup",
    "tui": "python3 scripts/lobster_tui.py"
  },
  "config": {
    "defaultModel": "local",
    "requiresNet": false,
    "autoRun": {
      "command": "health",
      "schedule": "0 6 * * 3"
    }
  },
  "files": [
    "README.md",
    "SKILL.md",
    "KNOWLEDGE.md",
    "scripts/",
    "tests/",
    "docs/",
    "requirements.txt"
  ]
}